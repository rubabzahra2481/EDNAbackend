# Server Configuration
PORT=3001
NODE_ENV=development

# AWS S3 Configuration
# Get these from AWS IAM Console
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
S3_BUCKET_NAME=your-s3-bucket-name

# GoHighLevel API
# Get these from GHL account
GHL_API_KEY=your-ghl-api-key
GHL_SENDER_EMAIL=your-sender-email@domain.com
GHL_SENDER_NAME=Your Name

# GoHighLevel Inbound Webhook
# This webhook URL is used to trigger GHL automation that sends emails with download links
GHL_INBOUND_WEBHOOK_URL=https://services.leadconnectorhq.com/hooks/GUAsdl1r4AN8xBT6u61i/webhook-trigger/25fd04e5-0e38-4cec-a2e0-58fd4ff69fa6

# Frontend URL
# Update this with your production frontend URL
FRONTEND_URL=https://main.d4edpf6ads6l4.amplifyapp.com/

# Backend Public URL
# This is the public URL of your backend (used for generating download links)
# Update this with your production backend URL
PUBLIC_BACKEND_BASE_URL=https://ry93w5zzjy.us-east-1.awsapprunner.com

# Supabase Configuration
# Get these from Supabase project settings
SUPABASE_SERVICE_KEY=your-supabase-service-role-key
SUPABASE_URL=https://your-project-id.supabase.co
